<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:padding="16dp">

    <!-- Header Section -->
    <TextView
        android:id="@+id/tvLightsTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Lights &amp; Fans"
        android:textColor="#FFFFFF"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <Button
        android:id="@+id/btnPowerAll"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:backgroundTint="#FF5252"
        android:text="⏻"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Brightness Controls -->
    <TextView
        android:id="@+id/tvBrightTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Brightness Master"
        android:textColor="#BBBBBB"
        android:textSize="16sp"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/tvLightsTitle"
        app:layout_constraintStart_toStartOf="parent" />

    <LinearLayout
        android:id="@+id/llBright"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal"
        android:weightSum="2"
        app:layout_constraintTop_toBottomOf="@id/tvBrightTitle">

        <Button
            android:id="@+id/btnDim"
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:backgroundTint="#424242"
            android:text="DIM 🔅"
            android:textColor="#FFFFFF"
            android:textSize="18sp" />

        <Button
            android:id="@+id/btnBright"
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:backgroundTint="#FFCA28"
            android:text="BRIGHT 💡"
            android:textColor="#000000"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Color Temperature -->
    <TextView
        android:id="@+id/tvTempTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Color Temperature"
        android:textColor="#BBBBBB"
        android:textSize="16sp"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/llBright"
        app:layout_constraintStart_toStartOf="parent" />

    <LinearLayout
        android:id="@+id/llColorTemp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal"
        android:weightSum="3"
        app:layout_constraintTop_toBottomOf="@id/tvTempTitle">

        <Button
            android:id="@+id/btnWarm"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:backgroundTint="#FF9800"
            android:text="WARM\n3000K"
            android:textColor="#FFFFFF"
            android:textSize="12sp" />

        <Button
            android:id="@+id/btnNeutral"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:backgroundTint="#BDBDBD"
            android:text="Daylight\n4000K"
            android:textColor="#000000"
            android:textSize="12sp" />

        <Button
            android:id="@+id/btnCool"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            android:backgroundTint="#03A9F4"
            android:text="COOL\n6000K"
            android:textColor="#FFFFFF"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- Fan / Motor Control -->
    <TextView
        android:id="@+id/tvFanTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Ceiling Fan Speed"
        android:textColor="#BBBBBB"
        android:textSize="16sp"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/llColorTemp"
        app:layout_constraintStart_toStartOf="parent" />

    <LinearLayout
        android:id="@+id/llFanControl"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal"
        android:weightSum="4"
        app:layout_constraintTop_toBottomOf="@id/tvFanTitle">

        <Button
            android:id="@+id/btnFanOff"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:backgroundTint="#333333"
            android:text="OFF"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/btnFan1"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:backgroundTint="#1976D2"
            android:text="1"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/btnFan2"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:backgroundTint="#2196F3"
            android:text="2"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/btnFan3"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            android:backgroundTint="#03A9F4"
            android:text="3"
            android:textColor="#FFFFFF" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>

<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:padding="16dp">

    <!-- Header Section -->
    <TextView
        android:id="@+id/tvAcTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="A/C Control"
        android:textColor="#FFFFFF"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <Button
        android:id="@+id/btnPower"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:backgroundTint="#FF5252"
        android:text="⏻"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- AC Status Display Screen -->
    <LinearLayout
        android:id="@+id/llDisplay"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:layout_marginTop="24dp"
        android:background="#1E1E1E"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/tvAcTitle">

        <TextView
            android:id="@+id/tvTempDisplay"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="24°C"
            android:textColor="#00E5FF"
            android:textSize="48sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <TextView
                android:id="@+id/tvModeDisplay"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="❄️ COOL"
                android:textColor="#BBBBBB"
                android:textSize="14sp"
                android:layout_marginEnd="16dp" />

            <TextView
                android:id="@+id/tvFanDisplay"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💨 AUTO"
                android:textColor="#BBBBBB"
                android:textSize="14sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Temperature Controls -->
    <Button
        android:id="@+id/btnTempUp"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_marginTop="32dp"
        android:backgroundTint="#424242"
        android:text="+"
        android:textColor="#FFFFFF"
        android:textSize="32sp"
        app:layout_constraintTop_toBottomOf="@id/llDisplay"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/btnTempDown"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_marginTop="16dp"
        android:backgroundTint="#424242"
        android:text="-"
        android:textColor="#FFFFFF"
        android:textSize="32sp"
        app:layout_constraintTop_toBottomOf="@id/btnTempUp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Mode and Fan Row -->
    <LinearLayout
        android:id="@+id/llModeFan"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:orientation="horizontal"
        android:weightSum="3"
        app:layout_constraintTop_toBottomOf="@id/btnTempDown">

        <Button
            android:id="@+id/btnMode"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:backgroundTint="#333333"
            android:text="MODE"
            android:textColor="#FFFFFF"/>

        <Button
            android:id="@+id/btnFan"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:backgroundTint="#333333"
            android:text="FAN"
            android:textColor="#FFFFFF"/>

        <Button
            android:id="@+id/btnSwing"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:backgroundTint="#333333"
            android:text="SWING"
            android:textColor="#FFFFFF"/>
    </LinearLayout>

    <!-- Smart Macro Row -->
    <TextView
        android:id="@+id/tvMacrosTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Smart Environment Scenes"
        android:textColor="#BBBBBB"
        android:textSize="16sp"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/llModeFan"
        app:layout_constraintStart_toStartOf="parent" />

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvMacrosTitle">
        
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnMacroTurbo"
                android:layout_width="wrap_content"
                android:layout_height="60dp"
                android:layout_marginEnd="8dp"
                android:backgroundTint="#2196F3"
                android:text="⚡ Turbo Cool (18°C)"
                android:textColor="#FFFFFF" />

            <Button
                android:id="@+id/btnMacroBedtime"
                android:layout_width="wrap_content"
                android:layout_height="60dp"
                android:layout_marginEnd="8dp"
                android:backgroundTint="#673AB7"
                android:text="🌙 Bedtime (25°C + Quiet)"
                android:textColor="#FFFFFF" />

            <Button
                android:id="@+id/btnMacroEco"
                android:layout_width="wrap_content"
                android:layout_height="60dp"
                android:backgroundTint="#4CAF50"
                android:text="🌱 Eco Mode (26°C)"
                android:textColor="#FFFFFF" />
        </LinearLayout>

    </HorizontalScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>

<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:padding="16dp">

    <!-- Header Section -->
    <TextView
        android:id="@+id/tvSoundbarTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Sound System"
        android:textColor="#FFFFFF"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <Button
        android:id="@+id/btnPower"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:backgroundTint="#FF5252"
        android:text="⏻"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Source Input Grid -->
    <GridLayout
        android:id="@+id/glInputs"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:columnCount="3"
        android:rowCount="2"
        app:layout_constraintTop_toBottomOf="@id/tvSoundbarTitle">

        <Button
            android:id="@+id/btnInputOptical"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_columnWeight="1"
            android:layout_marginEnd="4dp"
            android:layout_marginBottom="4dp"
            android:backgroundTint="#333333"
            android:text="OPTICAL"
            android:textColor="#FFFFFF"
            android:textSize="12sp" />

        <Button
            android:id="@+id/btnInputAux"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_columnWeight="1"
            android:layout_marginEnd="4dp"
            android:layout_marginBottom="4dp"
            android:backgroundTint="#333333"
            android:text="AUX"
            android:textColor="#FFFFFF"
            android:textSize="12sp" />

        <Button
            android:id="@+id/btnInputBluetooth"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_columnWeight="1"
            android:layout_marginBottom="4dp"
            android:backgroundTint="#2196F3"
            android:text="BLUETOOTH"
            android:textColor="#FFFFFF"
            android:textSize="12sp" />

        <Button
            android:id="@+id/btnInputHDMIARC"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_columnWeight="1"
            android:layout_marginEnd="4dp"
            android:backgroundTint="#333333"
            android:text="HDMI ARC"
            android:textColor="#FFFFFF"
            android:textSize="12sp" />

        <Button
            android:id="@+id/btnInputCoaxial"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_columnWeight="1"
            android:layout_marginEnd="4dp"
            android:backgroundTint="#333333"
            android:text="COAXIAL"
            android:textColor="#FFFFFF"
            android:textSize="12sp" />

        <Button
            android:id="@+id/btnInputUSB"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_columnWeight="1"
            android:backgroundTint="#333333"
            android:text="USB"
            android:textColor="#FFFFFF"
            android:textSize="12sp" />
    </GridLayout>

    <!-- Master Volume / Mute Circle -->
    <Button
        android:id="@+id/btnVolUp"
        android:layout_width="100dp"
        android:layout_height="80dp"
        android:layout_marginTop="32dp"
        android:backgroundTint="#424242"
        android:text="VOL +"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        app:layout_constraintTop_toBottomOf="@id/glInputs"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/btnMute"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_marginTop="16dp"
        android:backgroundTint="#757575"
        android:text="MUTE"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/btnVolUp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/btnVolDown"
        android:layout_width="100dp"
        android:layout_height="80dp"
        android:layout_marginTop="16dp"
        android:backgroundTint="#424242"
        android:text="VOL -"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        app:layout_constraintTop_toBottomOf="@id/btnMute"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- DSP/EQ Presets -->
    <TextView
        android:id="@+id/tvEQTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Sound Profiles / EQ"
        android:textColor="#BBBBBB"
        android:textSize="16sp"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/btnVolDown"
        app:layout_constraintStart_toStartOf="parent" />

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvEQTitle">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnEQMovie"
                android:layout_width="wrap_content"
                android:layout_height="60dp"
                android:layout_marginEnd="8dp"
                android:backgroundTint="#E91E63"
                android:text="🍿 Movie\n(Bass Boost)"
                android:textColor="#FFFFFF" />

            <Button
                android:id="@+id/btnEQMusic"
                android:layout_width="wrap_content"
                android:layout_height="60dp"
                android:layout_marginEnd="8dp"
                android:backgroundTint="#9C27B0"
                android:text="🎵 Music\n(Flat / Stereo)"
                android:textColor="#FFFFFF" />

            <Button
                android:id="@+id/btnEQVoice"
                android:layout_width="wrap_content"
                android:layout_height="60dp"
                android:layout_marginEnd="8dp"
                android:backgroundTint="#00BCD4"
                android:text="🗣 Clear Voice\n(Enhance Dialog)"
                android:textColor="#FFFFFF" />

            <Button
                android:id="@+id/btnEQNight"
                android:layout_width="wrap_content"
                android:layout_height="60dp"
                android:backgroundTint="#607D8B"
                android:text="🌙 Night Mode\n(Dynamic Compression)"
                android:textColor="#FFFFFF" />
        </LinearLayout>
    </HorizontalScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
